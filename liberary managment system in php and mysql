

<?php
session_start();

/* 1. DATABASE CONNECTION */
$host = "localhost";
$user = "root";
$pass = "";
$db   = "database managment system";

try {
    $pdo = new PDO("mysql:host=$host", $user, $pass);
    $pdo->setAttribute(PDO::ATTR_ERRMODE, PDO::ERRMODE_EXCEPTION);
    
    $pdo->exec("CREATE DATABASE IF NOT EXISTS $db");
    $pdo->exec("USE $db");

    // Students Table
    $pdo->exec("CREATE TABLE IF NOT EXISTS students (
        student_id VARCHAR(10) PRIMARY KEY,
        password VARCHAR(255) NOT NULL
    )");

    // Initial Books Table creation
    $pdo->exec("CREATE TABLE IF NOT EXISTS books (
        id INT PRIMARY KEY,
        title VARCHAR(255),
        issued TINYINT(1) DEFAULT 0,
        borrower_id VARCHAR(10) DEFAULT NULL
    )");

    // ERROR HANDLING FOR MISSING AUTHOR COLUMN:
    // This checks if the 'author' column exists; if not, it adds it.
    $checkColumn = $pdo->query("SHOW COLUMNS FROM books LIKE 'author'");
    if (!$checkColumn->fetch()) {
        $pdo->exec("ALTER TABLE books ADD COLUMN author VARCHAR(255) AFTER title");
    }

} catch (PDOException $e) {
    die("Database Error: " . $e->getMessage());
}

$message = "";

/* 2. REGISTRATION */
if (isset($_POST['register'])) {
    $sid = trim($_POST['reg_id']);
    $pwd = password_hash($_POST['reg_pass'], PASSWORD_DEFAULT);

    if (preg_match('/^\d{5,10}$/', $sid)) {
        try {
            $stmt = $pdo->prepare("INSERT INTO students (student_id, password) VALUES (?, ?)");
            $stmt->execute([$sid, $pwd]);
            $message = "Registration successful!";
        } catch (Exception $e) {
            $message = "Error: ID already exists.";
        }
    } else {
        $message = "ID must be 5-7 digits.";
    }
}

/* 3. LOGIN */
if (isset($_POST['login'])) {
    $sid = $_POST['student_id'];
    $pwd = $_POST['password'];
    $stmt = $pdo->prepare("SELECT * FROM students WHERE student_id = ?");
    $stmt->execute([$sid]);
    $user = $stmt->fetch();

    if ($user && password_verify($pwd, $user['password'])) {
        $_SESSION['student_id'] = $sid;
    } else {
        $message = "Invalid login credentials!";
    }
}

/* 4. LOGOUT */
if (isset($_POST['logout'])) {
    session_destroy();
    header("Location: " . $_SERVER['PHP_SELF']);
    exit;
}

/* 5. ADD BOOK (With Logic Error Handling) */
if (isset($_POST['add_book']) && isset($_SESSION['student_id'])) {
    $bid = trim($_POST['book_id']);
    $btitle = trim($_POST['book_title']);
    $bauthor = trim($_POST['book_author']);
    
    // Validate inputs
    if (empty($bid)  empty($btitle)  empty($bauthor)) {
        $message = "Error: All fields (ID, Title, Author) are required.";
    } elseif (strlen($bauthor) < 3) {
        $message = "Error: Author name is too short.";
    } else {
        try {
            $stmt = $pdo->prepare("INSERT INTO books (id, title, author) VALUES (?, ?, ?)");
            $stmt->execute([$bid, $btitle, $bauthor]);
            $message = "Book added successfully!";
        } catch (Exception $e) {
            $message = "Error: Book ID $bid already exists.";
        }
    }
}

/* 6. ISSUE & RETURN */
if (isset($_POST['issue_book'])) {
    $bid = $_POST['issue_book_id'];
    $stmt = $pdo->prepare("UPDATE books SET issued=1, borrower_id=? WHERE id=? AND issued=0");
    $stmt->execute([$_SESSION['student_id'], $bid]);
    $message = $stmt->rowCount() ? "Book Borrowed!" : "Error: Book unavailable or ID incorrect.";
}

if (isset($_POST['return_book'])) {
    $bid = $_POST['return_book_id'];
    $stmt = $pdo->prepare("UPDATE books SET issued=0, borrower_id=NULL WHERE id=? AND borrower_id=?");
    $stmt->execute([$bid, $_SESSION['student_id']]);
    $message = $stmt->rowCount() ? "Book Returned!" : "Error: You are not the borrower of this book.";
}

$books = $pdo->query("SELECT * FROM books ORDER BY id DESC")->fetchAll(PDO::FETCH_ASSOC);
?>

